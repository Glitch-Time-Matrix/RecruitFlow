# ─────────────────────────────────────────────────────────────────────────────
# RecruitFlow RMS — Environment Variables (TEMPLATE)
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and NEVER committed. Do not put real keys here.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (public — safe to expose to the browser) ---
# Supabase dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase dashboard → Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (SECRET — server only, never sent to the browser) ---
# Supabase dashboard → Settings → API → Project API keys → service_role
# Used only in trusted server code (e.g. public form intake). Bypasses RLS — keep private.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# The public base URL of the app (used for links, redirects). Local default below.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
